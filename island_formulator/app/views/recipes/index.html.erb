<% content_for :title, "Recipes" %>

<div class="font-sans bg-cream min-h-screen p-8 text-ink">
  <div class="flex justify-between items-end pb-5 mb-10 border-b-2 border-rule">
    <h1 class="font-serif text-5xl font-normal text-ink">My Recipes</h1>
    <%= link_to "New Recipe", new_recipe_path,
        class: "font-sans text-[10px] tracking-[0.16em] uppercase font-bold no-underline bg-sagedk text-paper border-[1.5px] border-sagedk px-5 py-2.5 hover:bg-sage hover:border-sage" %>
  </div>

  <% if @recipes.empty? %>
    <div class="text-center py-16 px-8 bg-paper border-[1.5px] border-rule font-serif italic text-xl text-muted">
      <p class="mb-4">You haven't created any recipes yet.</p>
      <%= link_to "Create your first recipe", new_recipe_path,
          class: "text-sagedk no-underline border-b-[1.5px] border-sagedk" %>
    </div>
  <% else %>
    <div class="grid grid-cols-3 gap-7">
      <% @recipes.each do |recipe| %>
        <div class="bg-paper border-[1.5px] border-rule flex flex-col shadow-sm transition-shadow duration-200 hover:shadow-md">

          <% if recipe.photo.attached? %>
            <%= image_tag recipe.photo, class: "w-full h-[200px] object-cover block border-b-[1.5px] border-rule" %>
          <% else %>
            <div class="w-full h-[200px] bg-parchment border-b-[1.5px] border-rule flex items-center justify-center">
              <span class="font-serif italic text-muted text-base">No photo yet</span>
            </div>
          <% end %>

          <div class="p-5 flex-1">
            <% if recipe.product_type.present? %>
              <span class="text-[9px] tracking-[0.2em] uppercase font-bold text-golddk bg-goldbg border border-gold inline-block px-2.5 py-0.5 mb-3">
                <%= recipe.product_type %>
              </span>
            <% end %>
            <%= link_to recipe.title, recipe,
                class: "font-serif text-xl font-normal text-ink no-underline block mb-1 hover:text-sagedk" %>
            <p class="text-[11px] text-muted tracking-[0.05em]">
              <%= pluralize(recipe.ingredients.count, 'ingredient') %>
            </p>
          </div>

          <div class="px-5 py-3 border-t border-parchment bg-cream flex justify-between items-center">
            <%= link_to "View Recipe →", recipe,
                class: "text-[10px] tracking-[0.12em] uppercase font-bold text-sagedk no-underline border-b-[1.5px] border-sagedk pb-px hover:text-sage hover:border-sage" %>

            <% if current_user.favorites.exists?(recipe: recipe) %>
              <%= button_to "♥", recipe_favorite_path(recipe), method: :delete,
                  class: "text-lg text-rose bg-transparent border-none cursor-pointer leading-none",
                  title: "Remove from favourites" %>
            <% else %>
              <%= button_to "♡", recipe_favorite_path(recipe), method: :post,
                  class: "text-lg text-muted bg-transparent border-none cursor-pointer leading-none hover:text-rose",
                  title: "Add to favourites" %>
            <% end %>
          </div>

        </div>
      <% end %>
    </div>
  <% end %>
</div>
