<% content_for :title, @recipe.title %>

<div class="font-sans bg-cream min-h-screen p-8 text-ink">

  <%= link_to "← Back to Recipes", recipes_path,
      class: "text-[10px] tracking-[0.14em] uppercase font-bold text-muted no-underline border-b border-rule pb-px inline-block mb-7 hover:text-ink" %>

  <%# Header %>
  <div class="flex justify-between items-start pb-5 mb-8 border-b-2 border-rule gap-8">
    <div>
      <h1 class="font-serif text-5xl font-normal text-ink leading-tight mb-2"><%= @recipe.title %></h1>
      <% if @recipe.product_type.present? %>
        <span class="text-[9px] tracking-[0.2em] uppercase font-bold text-golddk bg-goldbg border border-gold inline-block px-2.5 py-0.5">
          <%= @recipe.product_type %>
        </span>
      <% end %>
    </div>
    <div class="flex gap-2 shrink-0 flex-wrap justify-end">
      <%= link_to "Edit", edit_recipe_path(@recipe),
          class: "font-sans text-[10px] tracking-[0.14em] uppercase font-bold no-underline text-muted border-[1.5px] border-rule px-4 py-2.5 hover:text-ink hover:border-ink" %>
      <%= link_to "Log a Batch", new_batch_path(recipe_id: @recipe.id),
          class: "font-sans text-[10px] tracking-[0.14em] uppercase font-bold no-underline bg-rosedk text-paper border-[1.5px] border-rosedk px-4 py-2.5 hover:bg-rose hover:border-rose" %>
      <%= button_to "Delete", @recipe, method: :delete,
          class: "font-sans text-[10px] tracking-[0.14em] uppercase font-bold bg-rosebg text-rosedk border-[1.5px] border-rose px-4 py-2.5 cursor-pointer hover:bg-rose hover:text-paper",
          data: { confirm: "Are you sure you want to delete this recipe?" } %>
      <%= link_to "Back", recipes_path,
          class: "font-sans text-[10px] tracking-[0.14em] uppercase font-bold no-underline text-muted border-[1.5px] border-rule px-4 py-2.5 hover:text-ink hover:border-ink" %>
    </div>
  </div>

  <%# Two column layout %>
  <div class="grid grid-cols-3 gap-8">

    <%# Left: photo + ingredients %>
    <div>
      <% if @recipe.photo.attached? %>
        <%= image_tag @recipe.photo, class: "w-full object-cover block border-[1.5px] border-rule" %>
      <% else %>
        <div class="w-full h-[260px] bg-parchment border-[1.5px] border-rule flex items-center justify-center">
          <span class="font-serif italic text-muted">No photo uploaded</span>
        </div>
      <% end %>

      <div class="bg-paper border-[1.5px] border-rule shadow-sm mt-6">
        <div class="h-[5px] bg-sage"></div>
        <div class="px-5 py-3 border-b border-parchment">
          <h2 class="font-serif text-lg italic font-normal text-ink">Ingredients</h2>
        </div>
        <% @recipe.recipe_ingredients.each do |ri| %>
          <div class="ms-row flex justify-between items-center px-5 py-3 border-b border-parchment last:border-b-0">
            <span class="text-sm text-ink"><%= ri.ingredient.name %></span>
            <span class="text-[12px] text-muted bg-parchment border border-rule px-2 py-0.5">
              <%= ri.quantity %>
            </span>
          </div>
        <% end %>
      </div>
    </div>

    <%# Right: method %>
    <div class="col-span-2">
      <div class="bg-paper border-[1.5px] border-rule shadow-sm h-full">
        <div class="h-[5px] bg-gold"></div>
        <div class="px-7 py-4 border-b border-parchment">
          <h2 class="font-serif text-lg italic font-normal text-ink">Method</h2>
        </div>
        <div class="px-7 py-6 text-[15px] leading-relaxed text-ink [&>p]:mb-4">
          <%= simple_format @recipe.method %>
        </div>
      </div>
    </div>

  </div>
</div>