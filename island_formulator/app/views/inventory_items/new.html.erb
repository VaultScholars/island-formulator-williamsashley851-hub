<% content_for :title, "New Inventory Item" %>

<div class="font-sans bg-cream min-h-screen p-8 text-ink">
  <%= link_to "← Back to Inventory", inventory_items_path,
      class: "text-[10px] tracking-[0.14em] uppercase font-bold text-muted no-underline border-b border-rule pb-px inline-block mb-7 hover:text-ink" %>
  <h1 class="font-serif text-4xl font-normal text-ink mb-8 pb-5 border-b-2 border-rule">Record a Purchase</h1>
  <%= render "form", inventory_item: @inventory_item %>
</div>
