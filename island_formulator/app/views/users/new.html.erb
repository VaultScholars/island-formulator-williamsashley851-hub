<% content_for :title, "Create Account" %>

<div class="font-sans flex min-h-screen">

  <%# Left — coral side %>
  <div class="hidden lg:flex lg:w-1/2 bg-coral relative flex-col items-center justify-center overflow-hidden px-16">

    <%# Decorative circles %>
    <div class="absolute top-[-80px] left-[-80px] w-[300px] h-[300px] rounded-full border border-white opacity-20"></div>
    <div class="absolute bottom-[60px] right-[-60px] w-[200px] h-[200px] rounded-full border border-white opacity-15"></div>
    <div class="absolute top-[180px] left-[40px] w-[120px] h-[120px] rounded-full bg-white opacity-10"></div>

    <div class="relative z-10 text-center">
      <h2 class="font-serif text-white font-normal mb-6" style="font-size:4.5rem;line-height:1;">
        Start<br>Creating<br>Today.
      </h2>
      <div class="flex items-center gap-3 justify-center mb-8">
        <div class="flex-1 h-px bg-white opacity-30"></div>
        <div class="w-[5px] h-[5px] bg-white rotate-45 shrink-0 opacity-60"></div>
        <div class="flex-1 h-px bg-white opacity-30"></div>
      </div>
      <p class="font-sans text-white text-sm tracking-[0.1em] uppercase opacity-80 mb-10">
        Recipes · Ingredients · Batches
      </p>

      <div class="text-left">
        <% ["Track all your formulations", "Manage ingredients & inventory", "Log every production batch"].each do |item| %>
          <div class="flex items-center gap-3 mb-4">
            <div class="w-[5px] h-[5px] bg-white rotate-45 shrink-0 opacity-80"></div>
            <p class="text-white text-sm font-sans tracking-[0.06em] opacity-85"><%= item %></p>
          </div>
        <% end %>
      </div>
    </div>

  </div>

  <%# Right — form side %>
  <div class="w-full lg:w-1/2 flex items-center justify-center bg-white px-10 py-16">
    <div class="w-full max-w-sm">

      <div class="mb-10">
        <p class="text-[10px] tracking-[0.22em] uppercase font-bold text-muted mb-2">Island Formulator</p>
        <h1 class="font-serif text-5xl font-normal text-ink leading-none">Create<br>Account.</h1>
        <div class="flex items-center gap-3 mt-5">
          <div class="flex-1 h-px bg-rule"></div>
          <div class="w-[5px] h-[5px] bg-coral rotate-45 shrink-0"></div>
          <div class="flex-1 h-px bg-rule"></div>
        </div>
      </div>

      <% if @user.errors.any? %>
        <div class="bg-rosebg border-[1.5px] border-rose px-5 py-4 mb-6">
          <h3 class="text-[12px] tracking-[0.1em] uppercase font-bold text-rosedk mb-2">
            Please fix the following
          </h3>
          <ul class="list-disc pl-5">
            <% @user.errors.full_messages.each do |message| %>
              <li class="text-[13px] text-rosedk mb-1"><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @user, url: users_path do |form| %>

        <div class="mb-5">
          <%= form.label :email_address,
              class: "text-[9px] tracking-[0.2em] uppercase font-bold text-muted block mb-2" %>
          <%= form.email_field :email_address,
              placeholder: "you@example.com", required: true,
              class: "block w-full bg-cream border-[1.5px] border-rule px-4 py-3 font-sans text-sm text-ink outline-none focus:border-coral" %>
        </div>

        <div class="mb-5">
          <%= form.label :password,
              class: "text-[9px] tracking-[0.2em] uppercase font-bold text-muted block mb-2" %>
          <%= form.password_field :password,
              placeholder: "Choose a strong password", required: true,
              class: "block w-full bg-cream border-[1.5px] border-rule px-4 py-3 font-sans text-sm text-ink outline-none focus:border-coral" %>
        </div>

        <div class="mb-8">
          <%= form.label :password_confirmation, "Confirm Password",
              class: "text-[9px] tracking-[0.2em] uppercase font-bold text-muted block mb-2" %>
          <%= form.password_field :password_confirmation,
              placeholder: "Type your password again", required: true,
              class: "block w-full bg-cream border-[1.5px] border-rule px-4 py-3 font-sans text-sm text-ink outline-none focus:border-coral" %>
        </div>

        <%= form.submit "Create Account",
            class: "w-full py-3 font-sans text-[11px] tracking-[0.2em] uppercase font-bold cursor-pointer bg-coral text-white border-none hover:bg-coraldark" %>

      <% end %>

      <p class="text-center text-sm text-muted mt-8">
        Already have an account?
        <%= link_to "Sign in", new_session_path,
            class: "font-bold text-coral no-underline border-b border-coral" %>
      </p>

    </div>
  </div>

</div>
