<% content_for :head do %>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
<% end %>

<div class="font-sans bg-cream min-h-screen p-8 text-ink">

  <%# Header %>
  <div class="flex justify-between items-end pb-5 mb-8 border-b-2 border-rule">
    <h1 class="font-serif text-5xl font-normal text-ink">
      Welcome back, <%= current_user.email_address.split('@').first.capitalize %>!
    </h1>
    <div class="text-[11px] tracking-[0.16em] uppercase text-muted font-bold">
      <%= Time.now.strftime("%A, %B %d, %Y") %>
    </div>
  </div>

  <%# Stats Grid %>
  <div class="grid grid-cols-4 border-[1.5px] border-rule mb-10 shadow-sm">
    <div class="stat-stripe stripe-sage bg-sagebg p-6 border-r-[1.5px] border-rule">
      <p class="text-[9px] tracking-[0.2em] uppercase font-bold text-sagedk mb-1">Ingredients</p>
      <p class="font-serif text-[3.4rem] font-normal leading-none text-sagedk mb-2"><%= @stats[:ingredients] %></p>
      <%= link_to "View all →", ingredients_path, class: "text-[10px] tracking-[0.1em] uppercase font-bold text-sagedk border-b-[1.5px] border-sagedk pb-px no-underline" %>
    </div>
    <div class="stat-stripe stripe-rose bg-rosebg p-6 border-r-[1.5px] border-rule">
      <p class="text-[9px] tracking-[0.2em] uppercase font-bold text-rosedk mb-1">Recipes</p>
      <p class="font-serif text-[3.4rem] font-normal leading-none text-rosedk mb-2"><%= @stats[:recipes] %></p>
      <%= link_to "View all →", recipes_path, class: "text-[10px] tracking-[0.1em] uppercase font-bold text-rosedk border-b-[1.5px] border-rosedk pb-px no-underline" %>
    </div>
    <div class="stat-stripe stripe-gold bg-goldbg p-6 border-r-[1.5px] border-rule">
      <p class="text-[9px] tracking-[0.2em] uppercase font-bold text-golddk mb-1">Inventory Items</p>
      <p class="font-serif text-[3.4rem] font-normal leading-none text-golddk mb-2"><%= @stats[:inventory] %></p>
      <%= link_to "View all →", inventory_items_path, class: "text-[10px] tracking-[0.1em] uppercase font-bold text-golddk border-b-[1.5px] border-golddk pb-px no-underline" %>
    </div>
    <div class="stat-stripe stripe-clay bg-claybg p-6">
      <p class="text-[9px] tracking-[0.2em] uppercase font-bold text-claydk mb-1">Total Batches</p>
      <p class="font-serif text-[3.4rem] font-normal leading-none text-claydk mb-2"><%= @stats[:batches] %></p>
      <%= link_to "View all →", batches_path, class: "text-[10px] tracking-[0.1em] uppercase font-bold text-claydk border-b-[1.5px] border-claydk pb-px no-underline" %>
    </div>
  </div>

  <%# Divider %>
  <div class="flex items-center gap-3 mb-8">
    <div class="flex-1 h-px bg-rule"></div>
    <div class="w-[7px] h-[7px] bg-sage rotate-45 shrink-0"></div>
    <div class="flex-1 h-px bg-rule"></div>
  </div>

  <%# Two columns %>
  <div class="grid grid-cols-2 gap-10 mb-10">

    <%# Recent Recipes %>
    <div>
      <div class="flex justify-between items-baseline mb-4">
        <h2 class="font-serif text-2xl italic font-normal text-ink">Recent Recipes</h2>
        <%= link_to "New Recipe", new_recipe_path,
            class: "text-[9px] tracking-[0.13em] uppercase font-bold no-underline border-[1.5px] border-sage text-sagedk bg-sagebg px-3 py-1" %>
      </div>
      <div class="border-[1.5px] border-rule shadow-sm">
        <% @recent_recipes.each do |recipe| %>
          <div class="ms-row flex justify-between items-center px-4 py-3 border-b border-parchment bg-paper last:border-b-0">
            <div>
              <%= link_to recipe.title, recipe, class: "font-serif text-base font-normal text-sagedk no-underline hover:border-b hover:border-sagedk" %>
              <p class="text-[10px] tracking-[0.05em] text-muted mt-0.5"><%= recipe.product_type %></p>
            </div>
            <span class="text-[11px] tracking-[0.05em] text-muted font-bold"><%= recipe.created_at.strftime("%b %d") %></span>
          </div>
        <% end %>
        <% if @recent_recipes.empty? %>
          <div class="px-4 py-10 text-center font-serif italic text-muted bg-paper">
            <p>No recipes yet.</p>
            <%= link_to "Create your first recipe", new_recipe_path, class: "text-sagedk no-underline border-b-[1.5px] border-sagedk" %>
          </div>
        <% end %>
      </div>
    </div>

    <%# Recent Batches %>
    <div>
      <div class="flex justify-between items-baseline mb-4">
        <h2 class="font-serif text-2xl italic font-normal text-ink">Recent Batches</h2>
        <%= link_to "Log Batch", new_batch_path,
            class: "text-[9px] tracking-[0.13em] uppercase font-bold no-underline border-[1.5px] border-rose text-rosedk bg-rosebg px-3 py-1" %>
      </div>
      <div class="border-[1.5px] border-rule shadow-sm">
        <% @recent_batches.each do |batch| %>
          <div class="ms-row flex justify-between items-center px-4 py-3 border-b border-parchment bg-paper last:border-b-0">
            <div>
              <p class="font-serif text-base font-normal text-ink"><%= batch.recipe.title %></p>
              <p class="text-[10px] tracking-[0.05em] text-muted mt-0.5 italic"><%= batch.notes.truncate(40) if batch.notes.present? %></p>
            </div>
            <div class="text-right">
              <span class="text-[11px] tracking-[0.05em] text-muted font-bold block"><%= batch.made_on.strftime("%b %d") %></span>
              <%= link_to "Details", batch, class: "text-[10px] tracking-[0.1em] uppercase font-bold text-rosedk no-underline" %>
            </div>
          </div>
        <% end %>
        <% if @recent_batches.empty? %>
          <div class="px-4 py-10 text-center font-serif italic text-muted bg-paper">
            <p>No batches logged yet.</p>
            <%= link_to "Log your first batch", new_batch_path, class: "text-sagedk no-underline border-b-[1.5px] border-sagedk" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Divider %>
  <div class="flex items-center gap-3 mb-8">
    <div class="flex-1 h-px bg-rule"></div>
    <div class="w-[7px] h-[7px] bg-rose rotate-45 shrink-0"></div>
    <div class="flex-1 h-px bg-rule"></div>
  </div>

  <%# Favourite Recipes %>
  <div class="mb-10">
    <div class="flex justify-between items-baseline mb-4">
      <h2 class="font-serif text-2xl italic font-normal text-ink">♥ Favourite Recipes</h2>
      <%= link_to "All Recipes", recipes_path,
          class: "text-[9px] tracking-[0.13em] uppercase font-bold no-underline border-[1.5px] border-rose text-rosedk bg-rosebg px-3 py-1" %>
    </div>
    <div class="border-[1.5px] border-rule shadow-sm">
      <% if @favorite_recipes.any? %>
        <% @favorite_recipes.each do |recipe| %>
          <div class="ms-row flex justify-between items-center px-4 py-3 border-b border-parchment bg-paper last:border-b-0">
            <div>
              <%= link_to recipe.title, recipe, class: "font-serif text-base font-normal text-rosedk no-underline hover:border-b hover:border-rosedk" %>
              <p class="text-[10px] tracking-[0.05em] text-muted mt-0.5"><%= recipe.product_type %></p>
            </div>
            <span class="text-rose font-bold">♥</span>
          </div>
        <% end %>
      <% else %>
        <div class="px-4 py-10 text-center font-serif italic text-muted bg-paper">
          <p>No favourites yet.</p>
          <p class="text-[11px] mt-2">Visit a recipe and click <span class="text-rose font-bold">♡ Favorite</span> to save it here.</p>
        </div>
      <% end %>
    </div>
  </div>

  <%# Quick Actions %>
  <div class="bg-sagebg border-[1.5px] border-sage p-8 text-center">
    <p class="font-serif text-[13px] tracking-[0.24em] uppercase italic font-semibold text-sagedk mb-5">Quick Actions</p>
    <div class="flex flex-wrap justify-center gap-3">
      <%= link_to "Add New Ingredient", new_ingredient_path,
          class: "font-sans text-[10px] tracking-[0.14em] uppercase font-bold text-ink bg-paper border-[1.5px] border-rule px-5 py-2.5 no-underline hover:bg-parchment hover:border-sage hover:text-sagedk" %>
      <%= link_to "Record Purchase", new_inventory_item_path,
          class: "font-sans text-[10px] tracking-[0.14em] uppercase font-bold text-ink bg-paper border-[1.5px] border-rule px-5 py-2.5 no-underline hover:bg-parchment hover:border-sage hover:text-sagedk" %>
      <%= link_to "Create Recipe", new_recipe_path,
          class: "font-sans text-[10px] tracking-[0.14em] uppercase font-bold text-ink bg-paper border-[1.5px] border-rule px-5 py-2.5 no-underline hover:bg-parchment hover:border-sage hover:text-sagedk" %>
      <%= link_to "Log Production", new_batch_path,
          class: "font-sans text-[10px] tracking-[0.14em] uppercase font-bold text-ink bg-paper border-[1.5px] border-rule px-5 py-2.5 no-underline hover:bg-parchment hover:border-sage hover:text-sagedk" %>
    </div>
  </div>

</div>