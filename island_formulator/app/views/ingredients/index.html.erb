<% content_for :title, "Ingredients" %>

<div class="font-sans bg-cream min-h-screen p-8 text-ink">

  <div class="flex justify-between items-end pb-5 mb-10 border-b-2 border-rule">
    <h1 class="font-serif text-5xl font-normal text-ink">My Ingredient Shelf</h1>
    <%= link_to "Add New Ingredient", new_ingredient_path,
        class: "font-sans text-[10px] tracking-[0.16em] uppercase font-bold no-underline bg-sagedk text-paper border-[1.5px] border-sagedk px-5 py-2.5 hover:bg-sage hover:border-sage" %>
  </div>

  <% if @ingredients.any? %>
    <div class="grid grid-cols-3 gap-7">
      <% @ingredients.each do |ingredient| %>
        <div class="bg-paper border-[1.5px] border-rule flex flex-col shadow-sm transition-shadow duration-200 hover:shadow-md">
          <div class="h-[5px] bg-sage"></div>
          <div class="p-5 flex-1">
            <% if ingredient.category.present? %>
              <span class="text-[9px] tracking-[0.2em] uppercase font-bold text-sagedk bg-sagebg border border-sage inline-block px-2.5 py-0.5 mb-3">
                <%= ingredient.category %>
              </span>
            <% end %>
            <h2 class="font-serif text-xl font-normal text-ink mb-2"><%= ingredient.name %></h2>
            <p class="text-[13px] text-muted leading-relaxed line-clamp-3"><%= ingredient.description %></p>
          </div>
          <div class="flex justify-between items-center px-5 py-3 border-t border-parchment bg-cream">
            <%= link_to "View Details →", ingredient,
                class: "text-[10px] tracking-[0.12em] uppercase font-bold text-sagedk no-underline border-b-[1.5px] border-sagedk pb-px hover:text-sage hover:border-sage" %>
            <span class="text-[11px] text-muted tracking-[0.06em]">#<%= ingredient.id %></span>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 px-8 font-serif italic text-xl text-muted">
      <p class="mb-4">Your shelf is empty.</p>
      <%= link_to "Add your first ingredient", new_ingredient_path,
          class: "text-sagedk no-underline border-b-[1.5px] border-sagedk" %>
    </div>
  <% end %>
</div>