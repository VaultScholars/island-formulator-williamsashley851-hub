<div id="<%= dom_id ingredient %>" class="font-sans text-ink mb-6">

  <div class="mb-4">
    <p class="text-[9px] tracking-[0.2em] uppercase font-bold text-muted mb-1">Name</p>
    <p class="font-serif text-lg text-ink"><%= ingredient.name %></p>
  </div>

  <div class="mb-4">
    <p class="text-[9px] tracking-[0.2em] uppercase font-bold text-muted mb-1">Category</p>
    <p class="text-sm text-ink"><%= ingredient.category.presence || "—" %></p>
  </div>

  <div class="mb-4">
    <p class="text-[9px] tracking-[0.2em] uppercase font-bold text-muted mb-1">Description</p>
    <p class="text-sm text-ink leading-relaxed"><%= ingredient.description.presence || "—" %></p>
  </div>

  <div class="mb-4">
    <p class="text-[9px] tracking-[0.2em] uppercase font-bold text-muted mb-1">Notes</p>
    <p class="text-sm text-ink italic"><%= ingredient.notes.presence || "—" %></p>
  </div>

  <div>
    <p class="text-[9px] tracking-[0.2em] uppercase font-bold text-muted mb-2">Tags</p>
    <% if ingredient.tags.any? %>
      <div class="flex flex-wrap gap-2">
        <% ingredient.tags.each do |tag| %>
          <span class="text-[9px] tracking-[0.14em] uppercase font-bold text-sagedk bg-sagebg border border-sage px-2.5 py-0.5">
            <%= tag.name %>
          </span>
        <% end %>
      </div>
    <% else %>
      <p class="text-[13px] text-muted italic">No tags selected</p>
    <% end %>
  </div>

</div>